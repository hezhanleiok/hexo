      font-size: 1.5rem;
    }

    .sidebar-header p {
      margin: 0 0 15px 0;
      opacity: 0.7;
      font-size: 0.9rem;
    }

    .user-info {
      display: flex;
      align-items: center;
      padding: 10px 0;
      font-size: 0.9rem;
      opacity: 0.8;
    }

    .user-info i {
      margin-right: 8px;
    }

    .sidebar-menu {
      padding: 20px 0;
    }

    .menu-item {
      display: flex;
      align-items: center;
      padding: 15px 20px;
      color: white;
      text-decoration: none;
      transition: all 0.3s;
      border-left: 4px solid transparent;
    }

    .menu-item:hover {
      background: #34495e;
      border-left-color: #3498db;
    }

    .menu-item.active {
      background: #34495e;
      border-left-color: #3498db;
    }

    .menu-item i {
      margin-right: 10px;
      width: 20px;
      text-align: center;
    }

    /* 退出登录按钮特殊样式 */
    #logoutBtn {
      margin-top: 20px;
      border-top: 1px solid #34495e;
    }

    .dashboard-main {
      flex: 1;
      padding: 0;
    }

    .dashboard-section {
      display: none;
      padding: 30px;
    }

    .dashboard-section.active {
      display: block;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      padding-bottom: 15px;
      border-bottom: 1px solid #e9ecef;
    }

    .section-header h2 {
      margin: 0;
      color: #2c3e50;
    }

    .editor-actions {
      display: flex;
      gap: 10px;
    }

    .btn {
      padding: 10px 20px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size: 14px;
      transition: all 0.3s;
    }

    .btn-primary {
      background: #3498db;
      color: white;
    }

    .btn-primary:hover {
      background: #2980b9;
    }

    .btn-secondary {
      background: #95a5a6;
      color: white;
    }

    .btn-secondary:hover {
      background: #7f8c8d;
    }

    .btn-small {
      padding: 5px 10px;
      font-size: 12px;
    }

    .btn-danger {
      background: #e74c3c;
      color: white;
    }

    .form-group {
      margin-bottom: 20px;
    }

    .form-row {
      display: flex;
      gap: 20px;
    }

    .form-group.half {
      flex: 1;
    }

    label {
      display: block;
      margin-bottom: 5px;
      font-weight: 600;
      color: #2c3e50;
    }

    .form-control {
      width: 100%;
      padding: 10px;
      border: 1px solid #ddd;
      border-radius: 5px;
      font-size: 14px;
    }

    .form-control:focus {
      outline: none;
      border-color: #3498db;
    }

    .editor-toolbar {
      display: flex;
      align-items: center;
      padding: 10px;
      background: #f8f9fa;
      border: 1px solid #ddd;
      border-bottom: none;
      border-radius: 5px 5px 0 0;
      flex-wrap: wrap;
      gap: 5px;
    }

    .tool-btn {
      padding: 8px 12px;
      border: 1px solid #ddd;
      background: white;
      border-radius: 3px;
      cursor: pointer;
      transition: all 0.3s;
    }

    .tool-btn:hover {
      background: #e9ecef;
    }

    .tool-separator {
      width: 1px;
      height: 20px;
      background: #ddd;
      margin: 0 5px;
    }

    .tool-select {
      padding: 6px;
      border: 1px solid #ddd;
      border-radius: 3px;
      background: white;
      font-size: 12px;
    }

    .editor-content {
      border: 1px solid #ddd;
      border-top: none;
      border-radius: 0 0 5px 5px;
      min-height: 400px;
      padding: 20px;
      font-size: 14px;
      line-height: 1.6;
    }

    .content-editable {
      outline: none;
      min-height: 360px;
    }

    .content-editable:focus {
      outline: none;
    }

    .cover-preview {
      margin-top: 10px;
      max-width: 200px;
      border: 1px solid #ddd;
      border-radius: 5px;
      overflow: hidden;
    }

    .cover-preview img {
      width: 100%;
      height: auto;
      display: block;
    }

    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #95a5a6;
    }

    .empty-state i {
      font-size: 48px;
      margin-bottom: 15px;
    }

    /* 文章列表样式 */
    .articles-list {
      display: flex;
      flex-direction: column;
      gap: 15px;
    }

    .article-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px;
      border: 1px solid #e9ecef;
      border-radius: 8px;
      background: #fff;
      transition: box-shadow 0.3s;
    }

    .article-item:hover {
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .article-info {
      flex: 1;
      min-width: 0;
    }

    .article-info h3 {
      margin: 0 0 8px 0;
      color: #2c3e50;
      font-size: 1.1rem;
    }

    .article-meta {
      margin: 0;
      color: #7f8c8d;
      font-size: 0.9rem;
    }

    .article-actions {
      display: flex;
      gap: 8px;
      flex-shrink: 0;
      margin-left: 15px;
    }

    .category-item, .tag-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px;
      border: 1px solid #e9ecef;
      border-radius: 5px;
      margin-bottom: 10px;
    }

    .category-actions, .tag-actions {
      display: flex;
      gap: 5px;
    }
    
    /* 公告列表样式 */
    .announcements-list {
      display: flex;
      flex-direction: column;
      gap: 15px;
    }

    .announcement-item {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 20px;
      border: 1px solid #e9ecef;
      border-radius: 8px;
      background: #fff;
      transition: box-shadow 0.3s;
    }

    .announcement-item:hover {
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .announcement-info {
      flex: 1;
      min-width: 0;
    }

    .announcement-info h3 {
      margin: 0 0 8px 0;
      color: #2c3e50;
      font-size: 1.1rem;
    }

    .announcement-meta {
      margin: 0 0 10px 0;
      color: #7f8c8d;
      font-size: 0.9rem;
    }

    .announcement-content {
      color: #333;
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .announcement-actions {
      display: flex;
      gap: 8px;
      flex-shrink: 0;
      margin-left: 15px;
    }

    @media (max-width: 768px) {
      .dashboard-content {
        flex-direction: column;
      }
      
      .dashboard-sidebar {
        width: 100%;
      }
      
      .form-row {
        flex-direction: column;
        gap: 0;
      }
      
      .login-box {
        padding: 30px 20px;
      }
    }
