doctype html
html(lang=config.language)
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1, shrink-to-fit=no')
    title= page.title
    link(rel='icon' href=url_for(theme.favicon))
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css')
    style.
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
        color: #333;
        background: #f8f9fa;
      }
      
      #dashboard {
        min-height: 100vh;
        background: #f8f9fa;
      }
      
      .dashboard-container {
        display: flex;
        flex-direction: column;
        width: 100%;
        min-height: 100vh;
        background: white;
      }
      
      /* 登录表单样式 */
      #login-form {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 20px;
        background: #f8f9fa;
      }
      
      .login-box {
        width: 100%;
        max-width: 400px;
        padding: 40px;
        background: white;
        border-radius: 10px;
        box-shadow: 0 0 20px rgba(0,0,0,0.1);
      }
      
      .login-header {
        text-align: center;
        margin-bottom: 30px;
      }
      
      .login-header h2 {
        margin: 0 0 10px 0;
        color: #2c3e50;
        font-size: 1.8rem;
      }
      
      .login-header p {
        margin: 0;
        color: #7f8c8d;
      }
      
      .login-body .form-group {
        margin-bottom: 20px;
      }
      
      .login-error {
        color: #e74c3c;
        margin-top: 15px;
        text-align: center;
        font-size: 14px;
      }
      
      /* 后台管理内容样式 */
      .dashboard-content {
        display: flex;
        flex: 1;
        min-height: 100vh;
      }
      
      .dashboard-sidebar {
        width: 280px;
        background: #2c3e50;
        color: white;
        min-height: 100vh;
      }
      
      .sidebar-header {
        padding: 30px 20px;
        border-bottom: 1px solid #34495e;
      }
      
      .sidebar-header h3 {
        margin: 0 0 5px 0;
        font-size: 1.5rem;
      }
      
      .sidebar-header p {
        margin: 0 0 15px 0;
        opacity: 0.7;
        font-size: 0.9rem;
      }
      
      .user-info {
        display: flex;
        align-items: center;
        padding: 10px 0;
        font-size: 0.9rem;
        opacity: 0.8;
      }
      
      .user-info i {
        margin-right: 8px;
      }
      
      .sidebar-menu {
        padding: 20px 0;
      }
      
      .menu-item {
        display: flex;
        align-items: center;
        padding: 15px 20px;
        color: white;
        text-decoration: none;
        transition: all 0.3s;
        border-left: 4px solid transparent;
      }
      
      .menu-item:hover {
        background: #34495e;
        border-left-color: #3498db;
      }
      
      .menu-item.active {
        background: #34495e;
        border-left-color: #3498db;
      }
      
      .menu-item i {
        margin-right: 10px;
        width: 20px;
        text-align: center;
      }
      
      /* 退出登录按钮特殊样式 */
      #logoutBtn {
        margin-top: 20px;
        border-top: 1px solid #34495e;
      }
      
      .dashboard-main {
        flex: 1;
        padding: 0;
        min-height: 100vh;
      }
      
      .dashboard-section {
        display: none;
        padding: 30px;
        min-height: 100vh;
      }
      
      .dashboard-section.active {
        display: block;
      }
      
      .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 1px solid #e9ecef;
      }
      
      .section-header h2 {
        margin: 0;
        color: #2c3e50;
      }
      
      .editor-actions {
        display: flex;
        gap: 10px;
      }
      
      .btn {
        padding: 10px 20px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        font-size: 14px;
        transition: all 0.3s;
      }
      
      .btn-primary {
        background: #3498db;
        color: white;
      }
      
      .btn-primary:hover {
        background: #2980b9;
      }
      
      .btn-secondary {
        background: #95a5a6;
        color: white;
      }
      
      .btn-secondary:hover {
        background: #7f8c8d;
      }
      
      .btn-small {
        padding: 5px 10px;
        font-size: 12px;
      }
      
      .btn-danger {
        background: #e74c3c;
        color: white;
      }
      
      .form-group {
        margin-bottom: 20px;
      }
      
      .form-row {
        display: flex;
        gap: 20px;
      }
      
      .form-group.half {
        flex: 1;
      }
      
      label {
        display: block;
        margin-bottom: 5px;
        font-weight: 600;
        color: #2c3e50;
      }
      
      .form-control {
        width: 100%;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 5px;
        font-size: 14px;
      }
      
      .form-control:focus {
        outline: none;
        border-color: #3498db;
      }
      
      .editor-toolbar {
        display: flex;
        align-items: center;
        padding: 10px;
        background: #f8f9fa;
        border: 1px solid #ddd;
        border-bottom: none;
        border-radius: 5px 5px 0 0;
        flex-wrap: wrap;
        gap: 5px;
      }
      
      .tool-btn {
        padding: 8px 12px;
        border: 1px solid #ddd;
        background: white;
        border-radius: 3px;
        cursor: pointer;
        transition: all 0.3s;
      }
      
      .tool-btn:hover {
        background: #e9ecef;
      }
      
      .tool-separator {
        width: 1px;
        height: 20px;
        background: #ddd;
        margin: 0 5px;
      }
      
      .tool-select {
        padding: 6px;
        border: 1px solid #ddd;
        border-radius: 3px;
        background: white;
        font-size: 12px;
      }
      
      .editor-content {
        border: 1px solid #ddd;
        border-top: none;
        border-radius: 0 0 5px 5px;
        min-height: 400px;
        padding: 20px;
        font-size: 14px;
        line-height: 1.6;
      }
      
      .content-editable {
        outline: none;
        min-height: 360px;
      }
      
      .content-editable:focus {
        outline: none;
      }
      
      .cover-preview {
        margin-top: 10px;
        max-width: 200px;
        border: 1px solid #ddd;
        border-radius: 5px;
        overflow: hidden;
      }
      
      .cover-preview img {
        width: 100%;
        height: auto;
        display: block;
      }
      
      .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #95a5a6;
      }
      
      .empty-state i {
        font-size: 48px;
        margin-bottom: 15px;
      }
      
      .category-item, .tag-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px;
        border: 1px solid #e9ecef;
        border-radius: 5px;
        margin-bottom: 10px;
      }
      
      .tag-item {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      
      .tag-count {
        color: #95a5a6;
        font-size: 14px;
      }
      
      .tag-hint {
        color: #7f8c8d;
        font-size: 14px;
        font-weight: normal;
      }
      
      .category-actions, .tag-actions {
        display: flex;
        gap: 5px;
      }
      
      @media (max-width: 768px) {
        .dashboard-content {
          flex-direction: column;
        }
        
        .dashboard-sidebar {
          width: 100%;
          min-height: auto;
        }
        
        .form-row {
          flex-direction: column;
          gap: 0;
        }
        
        .login-box {
          padding: 30px 20px;
        }
      }
  body
    #dashboard
      .dashboard-container
        #login-form
          .login-box
            .login-header
              h2 后台管理登录
              p 请输入账号和密码
            .login-body
              .form-group
                label(for="username") 用户名
                input#username.form-control(type="text" placeholder="请输入用户名")
              .form-group
                label(for="password") 密码
                input#password.form-control(type="password" placeholder="请输入密码")
              .form-group
                button.btn.btn-primary#loginBtn 登录
              .login-error#loginError
        
        #dashboard-content
          .dashboard-sidebar
            .sidebar-header
              h3 后台管理
              p 博客管理系统
              .user-info
                i.fas.fa-user
                span#usernameDisplay
            
            .sidebar-menu
              a.menu-item.active(href="#editor")
                i.fas.fa-edit
                span 文章编辑
              a.menu-item(href="#drafts")
                i.fas.fa-file-alt
                span 草稿管理
              a.menu-item(href="#published")
                i.fas.fa-check-circle
                span 已发布文章
              a.menu-item(href="#categories")
                i.fas.fa-folder
                span 分类管理
              a.menu-item(href="#tags")
                i.fas.fa-tags
                span 标签管理
              a.menu-item(href="#announcements")
                i.fas.fa-bullhorn
                span 公告管理
              a.menu-item(href="#comments")
                i.fas.fa-comments
                span 评论管理
              a.menu-item(href="#settings")
                i.fas.fa-cog
                span 系统设置
              a.menu-item(href="#" id="logoutBtn")
                i.fas.fa-sign-out-alt
                span 退出登录

          .dashboard-main
            #editor.dashboard-section.active
              .section-header
                h2 文章编辑器
                .editor-actions
                  button.btn.btn-secondary#saveDraft 保存草稿
                  button.btn.btn-primary#publishArticle 发布文章
              
              .editor-form
                .form-group
                  label(for="articleTitle") 文章标题
                  input#articleTitle.form-control(type="text" placeholder="请输入文章标题")
                
                .form-group
                  label(for="articleSlug") 文章别名
                  input#articleSlug.form-control(type="text" placeholder="文章URL别名")
                
                .form-group
                  label(for="articleContent") 文章内容
                  .editor-toolbar
                    button.tool-btn(type="button" data-command="bold")
                      i.fas.fa-bold
                    button.tool-btn(type="button" data-command="italic")
                      i.fas.fa-italic
                    button.tool-btn(type="button" data-command="underline")
                      i.fas.fa-underline
                    button.tool-btn(type="button" data-command="strikethrough")
                      i.fas.fa-strikethrough
                    .tool-separator
                    button.tool-btn(type="button" data-command="insertUnorderedList")
                      i.fas.fa-list-ul
                    button.tool-btn(type="button" data-command="insertOrderedList")
                      i.fas.fa-list-ol
                    .tool-separator
                    button.tool-btn(type="button" data-command="createLink")
                      i.fas.fa-link
                    button.tool-btn(type="button" data-command="unlink")
                      i.fas.fa-unlink
                    .tool-separator
                    button.tool-btn(type="button" data-command="insertImage")
                      i.fas.fa-image
                    button.tool-btn(type="button" data-command="insertVideo")
                      i.fas.fa-video
                    .tool-separator
                    select.tool-select#fontSize
                      option(value="") 字体大小
                      option(value="1") 小
                      option(value="3") 中
                      option(value="5") 大
                      option(value="7") 特大
                    select.tool-select#fontColor
                      option(value="") 字体颜色
                      option(value="#000000") 黑色
                      option(value="#ff0000") 红色
                      option(value="#00ff00") 绿色
                      option(value="#0000ff") 蓝色
                      option(value="#ffff00") 黄色
                    select.tool-select#fontFamily
                      option(value="") 字体
                      option(value="Arial") Arial
                      option(value="微软雅黑") 微软雅黑
                      option(value="宋体") 宋体
                      option(value="黑体") 黑体
                  
                  .editor-content
                    #articleContent.content-editable(contenteditable="true")
                      p 开始编写您的文章内容...
                
                .form-row
                  .form-group.half
                    label(for="articleCategories") 文章分类
                    select#articleCategories.form-control
                      option(value="") 请选择分类
                  
                  .form-group.half
                    label(for="articleTags") 文章标签
                    input#articleTags.form-control(type="text" placeholder="输入标签，用逗号分隔")
                
                .form-group
                  label(for="articleCover") 文章封面网址
                  input#articleCover.form-control(type="text" placeholder="请输入图片URL地址")
                  .cover-preview#coverPreview
                
                .form-group
                  label(for="articleExcerpt") 文章摘要
                  textarea#articleExcerpt.form-control(rows="3" placeholder="文章摘要（可选）")

            #drafts.dashboard-section
              .section-header
                h2 草稿管理
              .drafts-list
                .empty-state
                  i.fas.fa-file-alt
                  p 暂无草稿

            #published.dashboard-section
              .section-header
                h2 已发布文章
              .articles-list
                .empty-state
                  i.fas.fa-check-circle
                  p 暂无已发布文章

            #categories.dashboard-section
              .section-header
                h2 分类管理
                button.btn.btn-primary#addCategory 添加分类
              .categories-list
                .category-item
                  span.category-name 技术
                  .category-actions
                    button.btn.btn-small.btn-edit 编辑
                    button.btn.btn-small.btn-danger 删除

            #tags.dashboard-section
              .section-header
                h2 标签管理
                span.tag-hint (标签从文章中自动获取，删除标签会同步删除文章中的对应标签)
              .tags-list
                .empty-state
                  i.fas.fa-tags
                  p 暂无标签

            #announcements.dashboard-section
              .section-header
                h2 公告管理
                button.btn.btn-primary#addAnnouncement 发布公告
              .announcements-list
                .empty-state
                  i.fas.fa-bullhorn
                  p 暂无公告

            #comments.dashboard-section
              .section-header
                h2 评论管理
              .comments-list
                .empty-state
                  i.fas.fa-comments
                  p 暂无评论

            #settings.dashboard-section
              .section-header
                h2 系统设置
              .settings-form
                .form-group
                  label(for="blogTitle") 博客标题
                  input#blogTitle.form-control(type="text" value=config.title)
                
                .form-group
                  label(for="blogDescription") 博客描述
                  textarea#blogDescription.form-control(rows="3")= config.description || ''
                
                .form-group
                  label(for="authorName") 作者名称
                  input#authorName.form-control(type="text" value=config.author)

  // 从 Hexo 注入真实数据
  - const hexoTagsData = site.tags.data.map(tag => ({ id: tag._id, name: tag.name, slug: tag.slug, path: tag.path, length: tag.length }));
  - const hexoPostsData = site.posts.data.map(post => ({ id: post._id, title: post.title, content: post._content, cover: post.cover, slug: post.slug, tags: post.tags ? post.tags.map(t => t.name) : [], categories: post.categories ? post.categories.map(c => c.name) : [], publishedAt: post.date, path: post.path }));
  
  script.
    // ========================================================
    // ⚠️ 紧急注意：如果你排查发现自定义域名无效，请把下面这行换成你 Worker 的默认 workers.dev 域名
    // ========================================================
    const API_BASE = "https://hexiaoyiok.dpdns.org/api";

    // 全局变量
    let currentUser = null;
    let categories = [];
    let tags = [];
    let articles = [];
    
    // 登录验证
    function validateLogin(username, password) {
      return username === 'admin' && password === '123456';
    }
    
    function checkLoginStatus() {
      const user = localStorage.getItem('currentUser');
      if (user) {
        currentUser = JSON.parse(user);
        showDashboard();
      } else {
        showLogin();
      }
    }
    
    function showLogin() {
      document.getElementById('login-form').style.display = 'flex';
      document.getElementById('dashboard-content').style.display = 'none';
    }
    
    function showDashboard() {
      document.getElementById('login-form').style.display = 'none';
      document.getElementById('dashboard-content').style.display = 'flex';
      document.getElementById('usernameDisplay').textContent = currentUser.username;
    }
    
    function handleLogin() {
      const username = document.getElementById('username').value;
      const password = document.getElementById('password').value;
      const errorElement = document.getElementById('loginError');
      
      if (!username || !password) {
        errorElement.textContent = '请输入用户名和密码';
        return;
      }
      
      if (validateLogin(username, password)) {
        currentUser = { username };
        localStorage.setItem('currentUser', JSON.stringify(currentUser));
        showDashboard();
        errorElement.textContent = '';
      } else {
        errorElement.textContent = '用户名或密码错误';
      }
    }
    
    function handleLogout() {
      localStorage.removeItem('currentUser');
      currentUser = null;
      showLogin();
    }
    
    // ★ 修复：动态合并 Hexo 真实数据，确保分类和首页 100% 同步
    function loadData() {
      const hexoTags = !{JSON.stringify(hexoTagsData)};
      const hexoPosts = !{JSON.stringify(hexoPostsData)};
      
      tags = hexoTags;
      localStorage.setItem('tags', JSON.stringify(tags));
      
      const localArticles = JSON.parse(localStorage.getItem('publishedArticles') || '[]');
      const articlesMap = new Map();
      const uniqueCats = new Set();
      
      // 读取真实文章和分类
      hexoPosts.forEach(post => {
        articlesMap.set(String(post.id), post);
        if (post.categories) {
            post.categories.forEach(c => uniqueCats.add(c));
        }
      });
      
      localArticles.forEach(article => {
        const idStr = String(article.id);
        if (!articlesMap.has(idStr)) {
          if (!article.path) article.path = 'post/' + idStr;
          articlesMap.set(idStr, article);
        }
      });
      
      articles = Array.from(articlesMap.values());
      localStorage.setItem('publishedArticles', JSON.stringify(articles));
      
      // 合并本地缓存的分类（防止用户新建的还没生成页面时丢失）
      const localCats = JSON.parse(localStorage.getItem('categories') || '[]');
      localCats.forEach(c => uniqueCats.add(c.name));

      // 重新生成分类列表
      categories = Array.from(uniqueCats).map((name, i) => ({ id: i + 1, name: name }));
      if (categories.length === 0) {
          categories = [{ id: 1, name: '技术' }, { id: 2, name: '生活' }];
      }
      localStorage.setItem('categories', JSON.stringify(categories));
    }
    
    function saveCategories() {
      localStorage.setItem('categories', JSON.stringify(categories));
    }
    
    // 渲染分类
    function renderCategories() {
      const categoriesList = document.querySelector('.categories-list');
      if (categoriesList) {
        categoriesList.innerHTML = '';
        if (categories.length === 0) {
          categoriesList.innerHTML = `<div class="empty-state"><i class="fas fa-folder"></i><p>暂无分类</p></div>`;
          return;
        }
        
        categories.forEach(category => {
          const categoryItem = document.createElement('div');
          categoryItem.className = 'category-item';
          categoryItem.innerHTML = `
            <span class="category-name">${category.name}</span>
            <div class="category-actions">
              <button class="btn btn-small btn-danger" data-id="${category.id}">删除</button>
            </div>
          `;
          categoriesList.appendChild(categoryItem);
        });
        
        document.querySelectorAll('.category-actions .btn-danger').forEach(btn => {
          btn.addEventListener('click', function() {
            const id = parseInt(this.dataset.id);
            if (confirm('确定要删除这个分类吗？')) {
              categories = categories.filter(c => c.id !== id);
              saveCategories();
              renderCategories();
              updateArticleCategories();
            }
          });
        });
      }
    }
    
    // 更新下拉菜单
    function updateArticleCategories() {
      const categoriesSelect = document.getElementById('articleCategories');
      if (categoriesSelect) {
        categoriesSelect.innerHTML = '<option value="">请选择分类</option>';
        categories.forEach(category => {
          const option = document.createElement('option');
          option.value = category.name;
          option.textContent = category.name;
          categoriesSelect.appendChild(option);
        });
      }
    }
    
    // ★ 修复：完美还原文章列表，加回【编辑】按钮
    function renderArticles() {
      const articlesList = document.querySelector('.articles-list');
      if (articlesList) {
        articlesList.innerHTML = '';
        if (articles.length === 0) {
          articlesList.innerHTML = `<div class="empty-state"><i class="fas fa-check-circle"></i><p>暂无已发布文章</p></div>`;
          return;
        }
        
        articles.forEach(article => {
          const articleItem = document.createElement('div');
          articleItem.className = 'article-item';
          articleItem.innerHTML = `
            <div class="article-info">
              <h3>${article.title}</h3>
              <p class="article-meta">
                发布时间: ${new Date(article.publishedAt).toLocaleString()}
                ${article.categories && article.categories.length > 0 ? ` | 分类: ${article.categories.join(', ')}` : ''}
                ${article.tags && article.tags.length > 0 ? ` | 标签: ${article.tags.join(', ')}` : ''}
              </p>
            </div>
            <div class="article-actions">
              <button class="btn btn-small btn-edit" data-id="${article.id}">编辑</button>
              <button class="btn btn-small btn-danger" data-id="${article.id}">删除记录</button>
            </div>
          `;
          articlesList.appendChild(articleItem);
        });
        
        const articlesListClickHandler = function(e) {
          let target = e.target;
          if (!target.classList.contains('btn-danger') && !target.classList.contains('btn-edit')) {
            target = target.closest('.btn-danger, .btn-edit');
          }
          if (!target) return;
          
          // 点击编辑按钮
          if (target.classList.contains('btn-edit')) {
            const idStr = target.dataset.id;
            const article = articles.find(a => String(a.id) === idStr);
            if (article) {
              document.getElementById('articleTitle').value = article.title || '';
              document.getElementById('articleContent').innerHTML = article.content || '<p>文章内容加载中...</p>';
              
              updateArticleCategories();
              const catSelect = document.getElementById('articleCategories');
              if (catSelect && article.categories && article.categories.length > 0) {
                catSelect.value = article.categories[0];
              }
              
              document.getElementById('articleTags').value = article.tags ? article.tags.join(', ') : '';
              
              // 切换到编辑器界面
              document.querySelectorAll('.menu-item').forEach(nav => nav.classList.remove('active'));
              document.querySelectorAll('.dashboard-section').forEach(sec => sec.classList.remove('active'));
              document.querySelector('.menu-item[href="#editor"]').classList.add('active');
              document.getElementById('editor').classList.add('active');
              window.scrollTo(0, 0);
            }
          }

          // 点击删除按钮
          if (target.classList.contains('btn-danger')) {
            const idStr = target.dataset.id;
            if (confirm('确定要在本地移除这篇文章的记录吗？')) {
              articles = articles.filter(a => String(a.id) !== idStr);
              localStorage.setItem('publishedArticles', JSON.stringify(articles));
              renderArticles();
            }
          }
        };
        
        const oldListener = articlesList._clickListener;
        if (oldListener) articlesList.removeEventListener('click', oldListener);
        articlesList._clickListener = articlesListClickHandler;
        articlesList.addEventListener('click', articlesListClickHandler);
      }
    }
    
    // 渲染草稿与标签
    function renderDrafts() {
      const draftsList = document.querySelector('.drafts-list');
      if (draftsList) {
        const drafts = [];
        for (let i = 0; i < localStorage.length; i++) {
          const key = localStorage.key(i);
          if (key.startsWith('draft_')) drafts.push(JSON.parse(localStorage.getItem(key)));
        }
        draftsList.innerHTML = '';
        if (drafts.length === 0) {
          draftsList.innerHTML = `<div class="empty-state"><i class="fas fa-file-alt"></i><p>暂无草稿</p></div>`;
          return;
        }
        drafts.forEach(draft => {
          const draftItem = document.createElement('div');
          draftItem.className = 'draft-item';
          draftItem.innerHTML = `
            <div class="draft-info"><h3>${draft.title || '无标题'}</h3><p class="draft-meta">保存时间: ${new Date(draft.timestamp).toLocaleString()}</p></div>
            <div class="draft-actions"><button class="btn btn-small btn-danger" onclick="localStorage.removeItem('draft_${draft.timestamp}'); renderDrafts();">删除</button></div>
          `;
          draftsList.appendChild(draftItem);
        });
      }
    }
    
    function renderTags() {
      const tagsList = document.querySelector('.tags-list');
      if (tagsList) {
        tagsList.innerHTML = tags.length === 0 ? `<div class="empty-state"><i class="fas fa-tags"></i><p>暂无标签</p></div>` : '';
        tags.forEach(tag => {
          const tagItem = document.createElement('div');
          tagItem.className = 'tag-item';
          tagItem.innerHTML = `<span class="tag-name">${tag.name}</span><span class="tag-count">(${tag.length || 0} 篇文章)</span>`;
          tagsList.appendChild(tagItem);
        });
      }
    }

    // ========================================================
    // Cloudflare 网络请求逻辑
    // ========================================================
    async function loadAnnouncements() {
      const listEl = document.querySelector('.announcements-list');
      if (!listEl) return;
      listEl.innerHTML = '<p style="text-align:center; padding:20px;">正在从云端加载公告...</p>';
      try {
        const response = await fetch(`${API_BASE}/announcements`);
        if(!response.ok) throw new Error("网络响应不正常");
        const data = await response.json();
        listEl.innerHTML = '';
        if (data.length === 0) {
          listEl.innerHTML = `<div class="empty-state"><i class="fas fa-bullhorn"></i><p>暂无公告</p></div>`;
          return;
        }
        data.forEach(item => {
          const div = document.createElement('div');
          div.className = 'announcement-item';
          div.innerHTML = `<div class="announcement-info"><p class="announcement-meta">发布时间: ${new Date(item.date).toLocaleString()}</p><div class="announcement-content">${item.content}</div></div>`;
          listEl.appendChild(div);
        });
      } catch (err) {
        listEl.innerHTML = '<p style="text-align:center; color:red;">网络请求失败，请检查 Cloudflare 域名或 Worker 设置</p>';
      }
    }

    async function loadComments() {
      const listEl = document.querySelector('.comments-list');
      if (!listEl) return;
      listEl.innerHTML = '<p style="text-align:center; padding:20px;">正在从云端加载评论...</p>';
      try {
        const response = await fetch(`${API_BASE}/comments`);
        if(!response.ok) throw new Error("网络响应不正常");
        const data = await response.json();
        listEl.innerHTML = '';
        if (data.length === 0) {
          listEl.innerHTML = `<div class="empty-state"><i class="fas fa-comments"></i><p>暂无评论</p></div>`;
          return;
        }
        data.forEach(item => {
          const div = document.createElement('div');
          div.className = 'comment-item';
          div.innerHTML = `<div class="comment-header"><span class="comment-author"><strong>${item.author || '访客'}</strong></span><span class="comment-time">${new Date(item.date).toLocaleString()}</span></div><div class="comment-content">${item.content}</div>`;
          listEl.appendChild(div);
        });
      } catch (err) {
        listEl.innerHTML = '<p style="text-align:center; color:red;">网络请求失败，请检查 Cloudflare 域名或 Worker 设置</p>';
      }
    }

    // ========================================================
    // 初始化及事件绑定
    // ========================================================
    document.addEventListener('DOMContentLoaded', function() {
      checkLoginStatus();
      loadData();
      
      const loginBtn = document.getElementById('loginBtn');
      if (loginBtn) loginBtn.addEventListener('click', handleLogin);
      const logoutBtn = document.getElementById('logoutBtn');
      if (logoutBtn) logoutBtn.addEventListener('click', function(e) { e.preventDefault(); handleLogout(); });
      const passwordInput = document.getElementById('password');
      if (passwordInput) passwordInput.addEventListener('keypress', function(e) { if (e.key === 'Enter') handleLogin(); });
      
      // 富文本编辑器工具栏
      document.querySelectorAll('.tool-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const command = this.dataset.command;
          if(command === 'insertImage' || command === 'insertVideo') {
            const url = prompt(command === 'insertImage' ? '请输入图片URL:' : '请输入视频URL:');
            if (url) {
              if(command === 'insertImage') document.execCommand('insertImage', false, url);
              else document.execCommand('insertHTML', false, `<video controls width="100%"><source src="${url}" type="video/mp4"></video>`);
            }
          } else {
            document.execCommand(command, false, null);
          }
          document.getElementById('articleContent').focus();
        });
      });

      const fsSelect = document.getElementById('fontSize'); if(fsSelect) fsSelect.addEventListener('change', function() { document.execCommand('fontSize', false, this.value); });
      const fcSelect = document.getElementById('fontColor'); if(fcSelect) fcSelect.addEventListener('change', function() { document.execCommand('foreColor', false, this.value); });
      const ffSelect = document.getElementById('fontFamily'); if(ffSelect) ffSelect.addEventListener('change', function() { document.execCommand('fontName', false, this.value); });

      // 菜单切换
      const menuItems = document.querySelectorAll('.menu-item');
      const sections = document.querySelectorAll('.dashboard-section');
      menuItems.forEach(item => {
        item.addEventListener('click', function(e) {
          e.preventDefault();
          const target = this.getAttribute('href').substring(1);
          if (target === '') return; 
          
          menuItems.forEach(i => i.classList.remove('active'));
          sections.forEach(s => s.classList.remove('active'));
          
          this.classList.add('active');
          document.getElementById(target).classList.add('active');
          
          if (target === 'categories') renderCategories();
          else if (target === 'tags') renderTags();
          else if (target === 'published') renderArticles();
          else if (target === 'drafts') renderDrafts();
          else if (target === 'editor') updateArticleCategories();
          else if (target === 'announcements') loadAnnouncements();
          else if (target === 'comments') loadComments();
        });
      });

      // 草稿
      const saveDraftBtn = document.getElementById('saveDraft');
      if (saveDraftBtn) {
        saveDraftBtn.addEventListener('click', function() {
          const articleData = { title: document.getElementById('articleTitle').value, content: document.getElementById('articleContent').innerHTML, timestamp: new Date().toISOString() };
          localStorage.setItem('draft_' + Date.now(), JSON.stringify(articleData));
          alert('草稿保存成功！');
          renderDrafts();
        });
      }

      // 封面预览
      const articleCoverInput = document.getElementById('articleCover');
      const coverPreview = document.getElementById('coverPreview');
      if (articleCoverInput && coverPreview) {
        articleCoverInput.addEventListener('input', function() {
          const url = this.value.trim();
          coverPreview.innerHTML = url ? `<img src="${url}" alt="封面预览" onerror="this.parentElement.innerHTML='<p style=color:#e74c3c>图片加载失败</p>'">` : '';
        });
      }

      // ★ 发送发布请求到 API
      const publishArticleBtn = document.getElementById('publishArticle');
      if (publishArticleBtn) {
        publishArticleBtn.addEventListener('click', async function() {
          const title = document.getElementById('articleTitle').value.trim();
          const content = document.getElementById('articleContent').innerHTML;
          const catSelect = document.getElementById('articleCategories');
          const category = catSelect ? catSelect.value : '';
          const tag = document.getElementById('articleTags').value.trim();

          if (!title) { alert('请输入文章标题！'); return; }
          if (!content || content === '<p>开始编写您的文章内容...</p>') { alert('文章内容不能为空！'); return; }

          publishArticleBtn.innerText = "请求发送中...";
          publishArticleBtn.disabled = true;

          try {
            const response = await fetch(`${API_BASE}/posts`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ title, content, category, tag })
            });
            const result = await response.json();
            
            if (result.success) {
                alert(result.msg);
                const newArticle = { id: Date.now(), title: title, content: content, publishedAt: new Date().toISOString(), categories: category ? [category] : [], tags: tag ? tag.split(',').map(t=>t.trim()) : [] };
                articles.unshift(newArticle);
                localStorage.setItem('publishedArticles', JSON.stringify(articles));
                
                document.getElementById('articleTitle').value = '';
                document.getElementById('articleContent').innerHTML = '<p>开始编写您的文章内容...</p>';
                if(catSelect) catSelect.selectedIndex = 0;
                document.getElementById('articleTags').value = '';
            } else {
                alert("发布失败：" + (result.error || "未知错误"));
            }
          } catch (err) {
            console.error(err);
            alert("网络请求失败 (CORS 或 接口宕机)。请检查第一步讲的 Cloudflare 域名配置！");
          } finally {
            publishArticleBtn.innerText = "发布文章";
            publishArticleBtn.disabled = false;
          }
        });
      }
      
      const addCategoryBtn = document.getElementById('addCategory');
      if (addCategoryBtn) {
        addCategoryBtn.addEventListener('click', function() {
          const categoryName = prompt('请输入分类名称:');
          if (categoryName) {
            categories.push({ id: Date.now(), name: categoryName });
            saveCategories();
            renderCategories();
            updateArticleCategories();
            alert('分类添加成功！');
          }
        });
      }
      
      const addAnnouncementBtn = document.getElementById('addAnnouncement');
      if (addAnnouncementBtn) {
        addAnnouncementBtn.addEventListener('click', async function() {
          const content = prompt('请输入要发布的公告内容:');
          if (content) {
            try {
                const response = await fetch(`${API_BASE}/announcements`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ content })
                });
                const result = await response.json();
                if (result.success) { alert('发布成功！'); loadAnnouncements(); } 
                else alert('发布失败: ' + result.error);
            } catch (err) {
                alert("网络请求失败，请检查 Worker 配置。");
            }
          }
        });
      }
      
      renderCategories();
      renderTags();
      renderArticles();
      renderDrafts();
      updateArticleCategories();
      
      const activeSection = document.querySelector('.dashboard-section.active');
      if (activeSection && activeSection.id === 'announcements') loadAnnouncements();
    });

