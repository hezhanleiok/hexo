doctype html
html(lang=config.language)
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1, shrink-to-fit=no')
    title= page.title
    link(rel='icon' href=url_for(theme.favicon))
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css')
    style.
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
        color: #333;
        background: #f8f9fa;
      }
      
      #dashboard {
        min-height: 100vh;
        background: #f8f9fa;
      }
      
      .dashboard-container {
        display: flex;
        flex-direction: column;
        width: 100%;
        min-height: 100vh;
        background: white;
      }
      
      /* 登录表单样式 */
      #login-form {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 20px;
        background: #f8f9fa;
      }
      
      .login-box {
        width: 100%;
        max-width: 400px;
        padding: 40px;
        background: white;
        border-radius: 10px;
        box-shadow: 0 0 20px rgba(0,0,0,0.1);
      }
      
      .login-header {
        text-align: center;
        margin-bottom: 30px;
      }
      
      .login-header h2 {
        margin: 0 0 10px 0;
        color: #2c3e50;
        font-size: 1.8rem;
      }
      
      .login-header p {
        margin: 0;
        color: #7f8c8d;
      }
      
      .login-body .form-group {
        margin-bottom: 20px;
      }
      
      .login-error {
        color: #e74c3c;
        margin-top: 15px;
        text-align: center;
        font-size: 14px;
      }
      
      /* 后台管理内容样式 */
      .dashboard-content {
        display: flex;
        flex: 1;
        min-height: 100vh;
      }
      
      .dashboard-sidebar {
        width: 280px;
        background: #2c3e50;
        color: white;
        min-height: 100vh;
      }
      
      .sidebar-header {
        padding: 30px 20px;
        border-bottom: 1px solid #34495e;
      }
      
      .sidebar-header h3 {
        margin: 0 0 5px 0;
        font-size: 1.5rem;
      }
      
      .sidebar-header p {
        margin: 0 0 15px 0;
        opacity: 0.7;
        font-size: 0.9rem;
      }
      
      .user-info {
        display: flex;
        align-items: center;
        padding: 10px 0;
        font-size: 0.9rem;
        opacity: 0.8;
      }
      
      .user-info i {
        margin-right: 8px;
      }
      
      .sidebar-menu {
        padding: 20px 0;
      }
      
      .menu-item {
        display: flex;
        align-items: center;
        padding: 15px 20px;
        color: white;
        text-decoration: none;
        transition: all 0.3s;
        border-left: 4px solid transparent;
      }
      
      .menu-item:hover {
        background: #34495e;
        border-left-color: #3498db;
      }
      
      .menu-item.active {
        background: #34495e;
        border-left-color: #3498db;
      }
      
      .menu-item i {
        margin-right: 10px;
        width: 20px;
        text-align: center;
      }
      
      /* 退出登录按钮特殊样式 */
      #logoutBtn {
        margin-top: 20px;
        border-top: 1px solid #34495e;
      }
      
      .dashboard-main {
        flex: 1;
        padding: 0;
        min-height: 100vh;
      }
      
      .dashboard-section {
        display: none;
        padding: 30px;
        min-height: 100vh;
      }
      
      .dashboard-section.active {
        display: block;
      }
      
      .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 1px solid #e9ecef;
      }
      
      .section-header h2 {
        margin: 0;
        color: #2c3e50;
      }
      
      .editor-actions {
        display: flex;
        gap: 10px;
      }
      
      .btn {
        padding: 10px 20px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        font-size: 14px;
        transition: all 0.3s;
      }
      
      .btn-primary {
        background: #3498db;
        color: white;
      }
      
      .btn-primary:hover {
        background: #2980b9;
      }
      
      .btn-secondary {
        background: #95a5a6;
        color: white;
      }
      
      .btn-secondary:hover {
        background: #7f8c8d;
      }
      
      .btn-small {
        padding: 5px 10px;
        font-size: 12px;
      }
      
      .btn-danger {
        background: #e74c3c;
        color: white;
      }
      
      .form-group {
        margin-bottom: 20px;
      }
      
      .form-row {
        display: flex;
        gap: 20px;
      }
      
      .form-group.half {
        flex: 1;
      }
      
      label {
        display: block;
        margin-bottom: 5px;
        font-weight: 600;
        color: #2c3e50;
      }
      
      .form-control {
        width: 100%;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 5px;
        font-size: 14px;
      }
      
      .form-control:focus {
        outline: none;
        border-color: #3498db;
      }
      
      .editor-toolbar {
        display: flex;
        align-items: center;
        padding: 10px;
        background: #f8f9fa;
        border: 1px solid #ddd;
        border-bottom: none;
        border-radius: 5px 5px 0 0;
        flex-wrap: wrap;
        gap: 5px;
      }
      
      .tool-btn {
        padding: 8px 12px;
        border: 1px solid #ddd;
        background: white;
        border-radius: 3px;
        cursor: pointer;
        transition: all 0.3s;
      }
      
      .tool-btn:hover {
        background: #e9ecef;
      }
      
      .tool-separator {
        width: 1px;
        height: 20px;
        background: #ddd;
        margin: 0 5px;
      }
      
      .tool-select {
        padding: 6px;
        border: 1px solid #ddd;
        border-radius: 3px;
        background: white;
        font-size: 12px;
      }
      
      .editor-content {
        border: 1px solid #ddd;
        border-top: none;
        border-radius: 0 0 5px 5px;
        min-height: 400px;
        padding: 20px;
        font-size: 14px;
        line-height: 1.6;
      }
      
      .content-editable {
        outline: none;
        min-height: 360px;
      }
      
      .content-editable:focus {
        outline: none;
      }
      
      .cover-preview {
        margin-top: 10px;
        max-width: 200px;
        border: 1px solid #ddd;
        border-radius: 5px;
        overflow: hidden;
      }
      
      .cover-preview img {
        width: 100%;
        height: auto;
        display: block;
      }
      
      .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #95a5a6;
      }
      
      .empty-state i {
        font-size: 48px;
        margin-bottom: 15px;
      }
      
      .category-item, .tag-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px;
        border: 1px solid #e9ecef;
        border-radius: 5px;
        margin-bottom: 10px;
      }
      
      .tag-item {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      
      .tag-count {
        color: #95a5a6;
        font-size: 14px;
      }
      
      .tag-hint {
        color: #7f8c8d;
        font-size: 14px;
        font-weight: normal;
      }
      
      .category-actions, .tag-actions {
        display: flex;
        gap: 5px;
      }
      
      @media (max-width: 768px) {
        .dashboard-content {
          flex-direction: column;
        }
        
        .dashboard-sidebar {
          width: 100%;
          min-height: auto;
        }
        
        .form-row {
          flex-direction: column;
          gap: 0;
        }
        
        .login-box {
          padding: 30px 20px;
        }
      }
  body
    #dashboard
      .dashboard-container
        #login-form
          .login-box
            .login-header
              h2 后台管理登录
              p 请输入账号和密码
            .login-body
              .form-group
                label(for="username") 用户名
                input#username.form-control(type="text" placeholder="请输入用户名")
              .form-group
                label(for="password") 密码
                input#password.form-control(type="password" placeholder="请输入密码")
              .form-group
                button.btn.btn-primary#loginBtn 登录
              .login-error#loginError
        
        #dashboard-content
          .dashboard-sidebar
            .sidebar-header
              h3 后台管理
              p 博客管理系统
              .user-info
                i.fas.fa-user
                span#usernameDisplay
            
            .sidebar-menu
              a.menu-item.active(href="#editor")
                i.fas.fa-edit
                span 文章编辑
              a.menu-item(href="#drafts")
                i.fas.fa-file-alt
                span 草稿管理
              a.menu-item(href="#published")
                i.fas.fa-check-circle
                span 已发布文章
              a.menu-item(href="#categories")
                i.fas.fa-folder
                span 分类管理
              a.menu-item(href="#tags")
                i.fas.fa-tags
                span 标签管理
              a.menu-item(href="#announcements")
                i.fas.fa-bullhorn
                span 公告管理
              a.menu-item(href="#comments")
                i.fas.fa-comments
                span 评论管理
              a.menu-item(href="#settings")
                i.fas.fa-cog
                span 系统设置
              a.menu-item(href="#" id="logoutBtn")
                i.fas.fa-sign-out-alt
                span 退出登录

          .dashboard-main
            #editor.dashboard-section.active
              .section-header
                h2 文章编辑器
                .editor-actions
                  button.btn.btn-secondary#saveDraft 保存草稿
                  button.btn.btn-primary#publishArticle 发布文章
              
              .editor-form
                .form-group
                  label(for="articleTitle") 文章标题
                  input#articleTitle.form-control(type="text" placeholder="请输入文章标题")
                
                .form-group
                  label(for="articleSlug") 文章别名
                  input#articleSlug.form-control(type="text" placeholder="文章URL别名")
                
                .form-group
                  label(for="articleContent") 文章内容
                  .editor-toolbar
                    button.tool-btn(type="button" data-command="bold")
                      i.fas.fa-bold
                    button.tool-btn(type="button" data-command="italic")
                      i.fas.fa-italic
                    button.tool-btn(type="button" data-command="underline")
                      i.fas.fa-underline
                    button.tool-btn(type="button" data-command="strikethrough")
                      i.fas.fa-strikethrough
                    .tool-separator
                    button.tool-btn(type="button" data-command="insertUnorderedList")
                      i.fas.fa-list-ul
                    button.tool-btn(type="button" data-command="insertOrderedList")
                      i.fas.fa-list-ol
                    .tool-separator
                    button.tool-btn(type="button" data-command="createLink")
                      i.fas.fa-link
                    button.tool-btn(type="button" data-command="unlink")
                      i.fas.fa-unlink
                    .tool-separator
                    button.tool-btn(type="button" data-command="insertImage")
                      i.fas.fa-image
                    button.tool-btn(type="button" data-command="insertVideo")
                      i.fas.fa-video
                    .tool-separator
                    select.tool-select#fontSize
                      option(value="") 字体大小
                      option(value="1") 小
                      option(value="3") 中
                      option(value="5") 大
                      option(value="7") 特大
                    select.tool-select#fontColor
                      option(value="") 字体颜色
                      option(value="#000000") 黑色
                      option(value="#ff0000") 红色
                      option(value="#00ff00") 绿色
                      option(value="#0000ff") 蓝色
                      option(value="#ffff00") 黄色
                    select.tool-select#fontFamily
                      option(value="") 字体
                      option(value="Arial") Arial
                      option(value="微软雅黑") 微软雅黑
                      option(value="宋体") 宋体
                      option(value="黑体") 黑体
                  
                  .editor-content
                    #articleContent.content-editable(contenteditable="true")
                      p 开始编写您的文章内容...
                
                .form-row
                  .form-group.half
                    label(for="articleCategories") 文章分类
                    select#articleCategories.form-control
                      option(value="") 请选择分类
                  
                  .form-group.half
                    label(for="articleTags") 文章标签
                    input#articleTags.form-control(type="text" placeholder="输入标签，用逗号分隔")
                
                .form-group
                  label(for="articleCover") 文章封面网址
                  input#articleCover.form-control(type="text" placeholder="请输入图片URL地址")
                  .cover-preview#coverPreview
                
                .form-group
                  label(for="articleExcerpt") 文章摘要
                  textarea#articleExcerpt.form-control(rows="3" placeholder="文章摘要（可选）")

            #drafts.dashboard-section
              .section-header
                h2 草稿管理
              .drafts-list
                .empty-state
                  i.fas.fa-file-alt
                  p 暂无草稿

            #published.dashboard-section
              .section-header
                h2 已发布文章
              .articles-list
                .empty-state
                  i.fas.fa-check-circle
                  p 暂无已发布文章

            #categories.dashboard-section
              .section-header
                h2 分类管理
                button.btn.btn-primary#addCategory 添加分类
              .categories-list
                .category-item
                  span.category-name 技术
                  .category-actions
                    button.btn.btn-small.btn-edit 编辑
                    button.btn.btn-small.btn-danger 删除

            #tags.dashboard-section
              .section-header
                h2 标签管理
                span.tag-hint (标签从文章中自动获取，删除标签会同步删除文章中的对应标签)
              .tags-list
                .empty-state
                  i.fas.fa-tags
                  p 暂无标签

            #announcements.dashboard-section
              .section-header
                h2 公告管理
                button.btn.btn-primary#addAnnouncement 发布公告
              .announcements-list
                .empty-state
                  i.fas.fa-bullhorn
                  p 暂无公告

            #comments.dashboard-section
              .section-header
                h2 评论管理
              .comments-list
                .empty-state
                  i.fas.fa-comments
                  p 暂无评论

            #settings.dashboard-section
              .section-header
                h2 系统设置
              .settings-form
                .form-group
                  label(for="blogTitle") 博客标题
                  input#blogTitle.form-control(type="text" value=config.title)
                
                .form-group
                  label(for="blogDescription") 博客描述
                  textarea#blogDescription.form-control(rows="3")= config.description || ''
                
                .form-group
                  label(for="authorName") 作者名称
                  input#authorName.form-control(type="text" value=config.author)

  // 从 Hexo 注入真实数据
  - const hexoTagsData = site.tags.data.map(tag => ({ id: tag._id, name: tag.name, slug: tag.slug, path: tag.path, length: tag.length }));
  - const hexoPostsData = site.posts.data.map(post => ({ id: post._id, title: post.title, content: post._content, cover: post.cover, slug: post.slug, tags: post.tags ? post.tags.map(t => t.name) : [], categories: post.categories ? post.categories.map(c => c.name) : [], publishedAt: post.date, path: post.path }));
  
  script.
      document.addEventListener('DOMContentLoaded', () => {
          // ==========================================
          // 侧边栏菜单切换逻辑 (保留你原有的 UI 逻辑)
          // ==========================================
          const menuItems = document.querySelectorAll('.menu-item');
          const contentSections = document.querySelectorAll('.content-section');

          menuItems.forEach(item => {
              item.addEventListener('click', (e) => {
                  e.preventDefault();
                  menuItems.forEach(nav => nav.classList.remove('active'));
                  contentSections.forEach(sec => sec.classList.remove('active'));
                  
                  item.classList.add('active');
                  const targetId = item.getAttribute('href').substring(1);
                  const targetSection = document.getElementById(targetId);
                  if (targetSection) targetSection.classList.add('active');

                  if (targetId === 'announcements') loadAnnouncements();
                  if (targetId === 'comments') loadComments();
              });
          });

          // ==========================================
          // 核心：对接你的 Cloudflare Worker 自定义域名
          // ==========================================
          const API_BASE = "https://hexiaoyiok.dpdns.org/api";

          // 1. 发布文章功能
          const publishBtn = document.getElementById('publish-post-btn');
          if (publishBtn) {
              publishBtn.addEventListener('click', async () => {
                  const title = document.getElementById('post-title').value.trim();
                  const content = document.getElementById('post-content').value.trim();
                  const category = document.getElementById('post-category').value.trim();
                  const tag = document.getElementById('post-tag').value.trim();

                  if (!title || !content) {
                      alert("文章标题和内容不能为空！");
                      return;
                  }

                  publishBtn.innerText = "发布中...";
                  publishBtn.disabled = true;

                  try {
                      const response = await fetch(`${API_BASE}/posts`, {
                          method: "POST",
                          headers: { "Content-Type": "application/json" },
                          body: JSON.stringify({ title, content, category, tag })
                      });
                      
                      const result = await response.json();
                      if (result.success) {
                          alert(result.msg);
                          document.getElementById('post-title').value = '';
                          document.getElementById('post-content').value = '';
                          document.getElementById('post-category').value = '';
                          document.getElementById('post-tag').value = '';
                      } else {
                          alert("发布失败：" + (result.error || "未知错误"));
                      }
                  } catch (err) {
                      alert("网络请求失败，请检查 Worker 接口是否正常。");
                      console.error(err);
                  } finally {
                      publishBtn.innerText = "发布文章";
                      publishBtn.disabled = false;
                  }
              });
          }

          // 2. 公告功能
          const publishAnnouncementBtn = document.getElementById('publish-announcement-btn');
          if (publishAnnouncementBtn) {
              publishAnnouncementBtn.addEventListener('click', async () => {
                  const content = document.getElementById('announcement-content').value.trim();
                  if (!content) {
                      alert("公告内容不能为空！");
                      return;
                  }

                  try {
                      const response = await fetch(`${API_BASE}/announcements`, {
                          method: "POST",
                          headers: { "Content-Type": "application/json" },
                          body: JSON.stringify({ content })
                      });
                      
                      const result = await response.json();
                      if (result.success) {
                          alert(result.msg);
                          document.getElementById('announcement-content').value = '';
                          loadAnnouncements();
                      }
                  } catch (err) {
                      console.error("保存公告失败", err);
                      alert("公告发布失败，请重试。");
                  }
              });
          }

          async function loadAnnouncements() {
              const listEl = document.getElementById('announcement-list');
              if (!listEl) return;
              
              listEl.innerHTML = '<p>加载中...</p>';
              try {
                  const response = await fetch(`${API_BASE}/announcements`);
                  const data = await response.json();
                  
                  listEl.innerHTML = '';
                  if (data.length === 0) {
                      listEl.innerHTML = '<p>暂无公告</p>';
                      return;
                  }

                  data.forEach(item => {
                      const div = document.createElement('div');
                      div.className = 'announcement-item';
                      div.innerHTML = `
                          <div class="time">${new Date(item.date).toLocaleString()}</div>
                          <div class="content">${item.content}</div>
                      `;
                      listEl.appendChild(div);
                  });
              } catch (err) {
                  console.error("读取公告失败", err);
                  listEl.innerHTML = '<p>加载失败，请检查网络</p>';
              }
          }

          // 3. 评论功能
          async function loadComments() {
              const listEl = document.getElementById('comment-list');
              if (!listEl) return;

              listEl.innerHTML = '<p>加载中...</p>';
              try {
                  const response = await fetch(`${API_BASE}/comments`);
                  const data = await response.json();
                  
                  listEl.innerHTML = '';
                  if (data.length === 0) {
                      listEl.innerHTML = '<p>暂无评论</p>';
                      return;
                  }

                  data.forEach(item => {
                      const div = document.createElement('div');
                      div.className = 'comment-item';
                      div.innerHTML = `
                          <div class="author"><strong>${item.author || '匿名'}</strong> - <span>${new Date(item.date).toLocaleString()}</span></div>
                          <div class="content">${item.content}</div>
                      `;
                      listEl.appendChild(div);
                  });
              } catch (err) {
                  console.error("读取评论失败", err);
                  listEl.innerHTML = '<p>加载失败，请检查网络</p>';
              }
          }

          // 初始化加载
          const activeSection = document.querySelector('.content-section.active');
          if (activeSection && activeSection.id === 'announcements') {
              loadAnnouncements();
          }
      });

