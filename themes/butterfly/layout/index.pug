extends includes/layout.pug

block content
  #hlog-home-layout
    
    //- 第一大部分：上半部分（左右分栏）
    .hlog-top-section
      
      //- 左侧：轮播板块
      .hlog-carousel-block
        #home-showcase-container
        
      //- 右侧：上下堆叠
      .hlog-right-block
        
        //- 右上：公告板块
        .hlog-card.announcement-card
          .card-header
            span.header-icon 📢
            span 最新公告
          .card-body
            ul.notice-list
              li: a(href="#") 欢迎访问 Hlog，这是一个完全开源免费的博客系统
              li: a(href="#") 更多新功能正在路上...
        
        //- 右下：特点推荐板块 (全新海报模式)
        .hlog-card.featured-poster-card
          .poster-background
            img#featured-poster-img(src="", alt="Featured Post")
          .poster-overlay
            span.poster-tag ⭐ 特别推荐
            h4#featured-poster-title 正在加载...

    //- 第二大部分：下半部分（最新文章列表，底部通栏）
    .hlog-bottom-section
      .section-heading
        span.heading-icon 📝
        h2 最新发布
      .post-list-container
        //- 【终极安全机制】使用 page.posts.data 获取当前页面的文章数组，有多少渲染多少，绝不报错白屏！
        - var latestPosts = page.posts.data || []
        each post in latestPosts
          .post-list-item
            if post.cover
              .post-cover-wrapper
                img(src=url_for(post.cover) alt=(post.title || '无标题'))
            .post-item-info
              h3.post-item-title
                a(href=url_for(post.path))= post.title || '无标题文章'
              .post-item-excerpt
                //- 【安全截取文本】确保即便文章没有任何内容，也不会导致打包编译崩溃
                - var rawContent = post.excerpt || post.content || '暂无内容...'
                - var cleanText = strip_html(rawContent).trim().substring(0, 120)
                = cleanText + '...'
              .post-item-meta
                span= date(post.date, 'YYYY/MM/DD')
                span  · 
                span 阅读更多内容...
      
      //- 追加引入 Hexo 的默认分页组件，文章多了以后可以在底部翻页
      include includes/pagination.pug
