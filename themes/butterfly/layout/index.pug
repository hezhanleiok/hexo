extends includes/layout.pug

block content
  //- 【致命修复】必须保留 recent-posts 包装器，否则 Butterfly 主题的 JS 会崩溃导致全白！
  #recent-posts.recent-posts(style="width: 100%;")
    #hlog-home-layout
      
      //- 上半部分（左右分栏）
      .hlog-top-section
        //- 左侧轮播
        .hlog-carousel-block
          #home-showcase-container
          
        //- 右侧堆叠
        .hlog-right-block
          .hlog-card.announcement-card
            .card-header
              span.header-icon 📢
              span 最新公告
            .card-body
              ul.notice-list
                li: a(href="/") 欢迎访问 Hlog 博客
                li: a(href="/") 更多新功能正在路上...
          
          .hlog-card.featured-poster-card
            .poster-background
              img#featured-poster-img(src="", alt="推荐")
            .poster-overlay
              span.poster-tag ⭐ 特别推荐
              h4#featured-poster-title 加载中...

      //- 下半部分（最新发布）
      .hlog-bottom-section
        .section-heading
          span.heading-icon 📝
          h2 最新发布
        .post-list-container
          //- 【极其安全的变量提取】确保不论遇到什么版本，绝对不会因为变量不存在而中断渲染
          - var postArray = page.posts ? (page.posts.data ? page.posts.data : (page.posts.toArray ? page.posts.toArray() : page.posts)) : []
          if postArray.length > 0
            each post, index in postArray
              if index < 5
                .post-list-item
                  if post.cover
                    .post-cover-wrapper
                      img(src=url_for(post.cover) alt=post.title || '封面')
                  .post-item-info
                    h3.post-item-title
                      a(href=url_for(post.path))= post.title || '无标题文章'
                    .post-item-excerpt
                      - var text = post.description || post.excerpt || post.content || '暂无内容...'
                      != truncate(strip_html(text), {length: 120, omission: '...'})
                    .post-item-meta
                      if post.date
                        span= date(post.date, 'YYYY/MM/DD')
                        span  · 
                      span 阅读更多...
          else
            div(style="text-align:center; padding:50px; color:#999; font-size:16px;") 暂无文章

      //- 翻页组件
      include includes/pagination.pug