extends includes/layout.pug

block content
  //- 已移除导致报错的 include ./includes/mixins/post-ui.pug
  
  #recent-posts.recent-posts
    if page.type == 'index' && page._page
      // 首页自定义布局容器
      #hlog-home-layout(style="width: 100%; display: flex; flex-direction: column; gap: 25px; margin-bottom: 40px;")
        
        // 第一部分：上半部分（左右分栏）
        .hlog-top-section(style="display: grid; grid-template-columns: 65% calc(35% - 20px); gap: 20px; width: 100%; min-height: 380px;")
          
          // 左侧：轮播图
          .hlog-carousel-block(style="width: 100%; height: 100%; background: #f4f6f8; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.05);")
            #home-showcase-container(style="width: 100%; height: 100%;")
          
          // 右侧：公告与推荐
          .hlog-right-block(style="display: flex; flex-direction: column; gap: 20px; height: 100%;")
            // 公告
            .hlog-card.announcement-card(style="flex: 1; background: #fff; border-radius: 12px; padding: 18px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); display: flex; flex-direction: column;")
              .card-header(style="font-size: 16px; font-weight: 700; color: #1f2937; margin-bottom: 15px; display: flex; align-items: center; gap: 8px;")
                span.header-icon 📢
                span 最新公告
              .card-body
                ul.notice-list(style="padding-left: 15px; margin: 0; font-size: 14px; line-height: 1.8;")
                  li: a(href="/", style="color: #4b5563; text-decoration: none;") 欢迎访问 Hlog 博客
                  li: a(href="/", style="color: #4b5563; text-decoration: none;") 更多新功能正在路上...
            
            // 特别推荐海报
            .hlog-card.featured-poster-card(style="flex: 1; position: relative; padding: 0; overflow: hidden; border-radius: 12px; display: flex; background: #111;")
              .poster-background(style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;")
                img#featured-poster-img(src="", alt="推荐", style="width: 100%; height: 100%; object-fit: cover; opacity: 0.65;")
              .poster-overlay(style="position: relative; z-index: 1; display: flex; flex-direction: column; justify-content: flex-end; padding: 20px; width: 100%; height: 100%; background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0) 80%); box-sizing: border-box;")
                span.poster-tag(style="display: inline-block; background: rgba(255,255,255,0.2); backdrop-filter: blur(4px); color: #fff; font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 20px; margin-bottom: 8px; width: fit-content;") ⭐ 特别推荐
                h4#featured-poster-title(style="color: #fff; margin: 0; font-size: 15px; line-height: 1.5; font-weight: 700; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;") 加载中...

        // 第二部分：下半部分（最新发布）
        .hlog-bottom-section(style="width: 100%;")
          .section-heading(style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px;")
            span.heading-icon 📝
            h2(style="margin: 0; font-size: 18px; font-weight: 700; border-left: 4px solid #3b82f6; padding-left: 12px;") 最新发布
          
          .post-list-container(style="display: flex; flex-direction: column; gap: 20px;")
            - var postArray = page.posts ? (page.posts.data || (page.posts.toArray ? page.posts.toArray() : [])) : []
            if postArray.length > 0
              each post, index in postArray
                if index < 5
                  .post-list-item(style="display: flex; background: #fff; border-radius: 12px; padding: 20px; gap: 25px; box-shadow: 0 4px 15px rgba(0,0,0,0.03);")
                    if post.cover
                      .post-cover-wrapper(style="width: 260px; height: 160px; border-radius: 8px; overflow: hidden; flex-shrink: 0;")
                        img(src=url_for(post.cover), alt=post.title || '封面', style="width: 100%; height: 100%; object-fit: cover;")
                    .post-item-info(style="flex: 1; display: flex; flex-direction: column; justify-content: space-between; padding: 5px 0;")
                      h3.post-item-title(style="margin: 0; font-size: 1.25rem; font-weight: 700;")
                        a(href=url_for(post.path), style="color: #111827; text-decoration: none;")= post.title || '无标题文章'
                      .post-item-excerpt(style="color: #6b7280; font-size: 14px; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;")
                        - var text = post.description || post.excerpt || post.content || '暂无内容...'
                        != truncate(strip_html(text), {length: 120, omission: '...'})
                      .post-item-meta(style="font-size: 13px; color: #9ca3af;")
                        if post.date
                          span= date(post.date, 'YYYY/MM/DD')
                          span  · 
                        span 阅读全文
            else
              div(style="text-align:center; padding:50px; color:#999; font-size:16px;") 暂无文章发布

    else
      // 非首页正常渲染文章列表
      each post in page.posts
        include includes/mixins/post-ui.pug
        +postItem(post)

    include includes/pagination.pug
