extends includes/layout.pug

block content
  // 第一行：左侧内容区（轮播 + 公告 + 特别文章）
  .home-first-row
    #home-showcase-container
      // 轮播图在左，公告和特别文章在右（由 JS 动态生成）

  // 第二行：最新文章（最近 5 篇，带封面、标题、概述）
  .home-latest-posts
    h2.section-title 最新文章
    .latest-posts-list
      - var latestPosts = page.posts.sort('date', -1).limit(5).toArray()
      each post in latestPosts
        .latest-post-item
          if post.cover
            .post-cover
              img(src=url_for(post.cover) alt=post.title)
          .post-info
            h3.post-title
              a(href=url_for(post.path))= post.title
            .post-excerpt= post.excerpt || strip_html(post.content).substring(0, 120)
